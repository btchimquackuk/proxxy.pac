function FindProxyForURL(url, host) { // ===== 1. Identity Provider (must bypass) ===== if (host === "login.microsoftonline.com" || host === "accounts.google.com" || host === "github.com") return "DIRECT"; // ===== 2. Resolve host ===== var ip = dnsResolve(host); var isToken = false; if (ip) { // Token IP range (Cloudflare internal) isToken = isInNet(ip, "100.80.0.0", "255.255.0.0"); // ===== 3. IPv4 Direct Ranges ===== if (isInNet(ip, "10.0.0.0", "255.0.0.0") || isInNet(ip, "172.16.0.0", "255.240.0.0") || isInNet(ip, "192.168.0.0", "255.255.0.0") || isInNet(ip, "127.0.0.0", "255.0.0.0") || (!isToken && isInNet(ip, "100.64.0.0", "255.192.0.0")) || isInNet(ip, "169.254.0.0", "255.255.0.0")) return "DIRECT"; } // ===== 4. IPv6 Direct Ranges ===== var ip6 = dnsResolveEx(host); if (ip6) { if (isInNet(ip6, "fc00::", "7f00::") || // Unique local (ULA) isInNet(ip6, "fe80::", "ffc0::")) // Link-local return "DIRECT"; } // ===== 5. Plain hostnames / .local ===== if (isPlainHostName(host) || dnsDomainIs(host, ".local")) return "DIRECT"; // ===== 6. Non-HTTP/S traffic ===== if (url.substring(0,5) !== "http:" && url.substring(0,6) !== "https:") return "DIRECT"; // ===== 7. Cloudflare infrastructure ===== if (dnsDomainIs(host, ".cloudflare.com") || dnsDomainIs(host, ".cloudflare-gateway.com") || dnsDomainIs(host, ".cloudflareaccess.com") || dnsDomainIs(host, ".cloudflarestatus.com")) return "DIRECT"; // ===== 8. Default: Force through Cloudflare Proxy ===== return "HTTPS zo9epr9ud5.proxy.cloudflare-gateway.com:443"; }